{
  "condition": {
    "and": [
      {
        "tag": "highway",
        "eq": "service"
      },
      {
        "not": {
          "tag": "service",
          "exists": true
        }
      }
    ]
  },
  "excludes": [
    "bicycle_road",
    "service_alley",
    "service_driveway",
    "service_emergency_access",
    "service_parking_aisle"
  ],
  "consts": {
    "minzoom": 11
  }
}
