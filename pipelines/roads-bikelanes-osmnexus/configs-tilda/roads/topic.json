{
  "table": "roads",
  "private": {
    "_implicit_oneway_confidence": "not_applicable"
  },
  "transforms": [
    {
      "output": "highway",
      "rules": [
        {
          "when": {
            "and": [
              {
                "tag": "highway",
                "exists": true
              },
              {
                "tag": "construction",
                "in_set": "allowed_highway"
              }
            ]
          },
          "value": {
            "tag": "construction"
          }
        }
      ]
    },
    {
      "output": "lifecycle",
      "rules": [
        {
          "when": {
            "and": [
              {
                "tag": "highway",
                "exists": true
              },
              {
                "tag": "construction",
                "in_set": "allowed_highway"
              }
            ]
          },
          "value": "construction"
        },
        {
          "when": {
            "and": [
              {
                "or": [
                  {
                    "tag": "access",
                    "eq": "no"
                  },
                  {
                    "and": [
                      {
                        "tag": "highway",
                        "eq": "cycleway"
                      },
                      {
                        "tag": "bicycle",
                        "eq": "no"
                      }
                    ]
                  },
                  {
                    "and": [
                      {
                        "tag": "highway",
                        "eq": "footway"
                      },
                      {
                        "tag": "foot",
                        "eq": "no"
                      }
                    ]
                  }
                ]
              },
              {
                "or": [
                  {
                    "tag": "access:reason",
                    "contains": "construction",
                    "case_insensitive": true
                  },
                  {
                    "tag": "access:reason",
                    "contains": "baustelle",
                    "case_insensitive": true
                  },
                  {
                    "tag": "description",
                    "contains": "construction",
                    "case_insensitive": true
                  },
                  {
                    "tag": "description",
                    "contains": "baustelle",
                    "case_insensitive": true
                  },
                  {
                    "tag": "note",
                    "contains": "construction",
                    "case_insensitive": true
                  },
                  {
                    "tag": "note",
                    "contains": "baustelle",
                    "case_insensitive": true
                  }
                ]
              }
            ]
          },
          "value": "construction_no_access"
        },
        {
          "when": {
            "and": [
              {
                "or": [
                  {
                    "tag": "access",
                    "eq": "no"
                  },
                  {
                    "and": [
                      {
                        "tag": "highway",
                        "eq": "cycleway"
                      },
                      {
                        "tag": "bicycle",
                        "eq": "no"
                      }
                    ]
                  },
                  {
                    "and": [
                      {
                        "tag": "highway",
                        "eq": "footway"
                      },
                      {
                        "tag": "foot",
                        "eq": "no"
                      }
                    ]
                  }
                ]
              },
              {
                "or": [
                  {
                    "tag": "description",
                    "contains": "sperrung",
                    "case_insensitive": true
                  },
                  {
                    "tag": "description",
                    "contains": "gesperrt",
                    "case_insensitive": true
                  },
                  {
                    "tag": "description",
                    "contains": "blockiert",
                    "case_insensitive": true
                  },
                  {
                    "tag": "description",
                    "contains": "blocked",
                    "case_insensitive": true
                  },
                  {
                    "tag": "description",
                    "contains": "closure",
                    "case_insensitive": true
                  },
                  {
                    "tag": "description",
                    "contains": "closed",
                    "case_insensitive": true
                  },
                  {
                    "tag": "note",
                    "contains": "sperrung",
                    "case_insensitive": true
                  },
                  {
                    "tag": "note",
                    "contains": "gesperrt",
                    "case_insensitive": true
                  },
                  {
                    "tag": "note",
                    "contains": "blockiert",
                    "case_insensitive": true
                  },
                  {
                    "tag": "note",
                    "contains": "blocked",
                    "case_insensitive": true
                  },
                  {
                    "tag": "note",
                    "contains": "closure",
                    "case_insensitive": true
                  },
                  {
                    "tag": "note",
                    "contains": "closed",
                    "case_insensitive": true
                  }
                ]
              }
            ]
          },
          "value": "blocked"
        }
      ]
    },
    {
      "output": "construction",
      "rules": [
        {
          "when": {
            "tag": "lifecycle",
            "eq": "construction"
          },
          "value": null
        }
      ]
    },
    {
      "output": "access",
      "rules": [
        {
          "when": {
            "tag": "lifecycle",
            "in": [
              "construction_no_access",
              "blocked"
            ]
          },
          "value": null
        }
      ]
    },
    {
      "output": "bicycle",
      "rules": [
        {
          "when": {
            "and": [
              {
                "tag": "lifecycle",
                "in": [
                  "construction_no_access",
                  "blocked"
                ]
              },
              {
                "tag": "highway",
                "eq": "cycleway"
              }
            ]
          },
          "value": null
        }
      ]
    },
    {
      "output": "foot",
      "rules": [
        {
          "when": {
            "and": [
              {
                "tag": "lifecycle",
                "in": [
                  "construction_no_access",
                  "blocked"
                ]
              },
              {
                "tag": "highway",
                "eq": "footway"
              }
            ]
          },
          "value": null
        }
      ]
    },
    {
      "prefix": "cycleway"
    },
    {
      "output": "traffic_sign",
      "rules": [
        {
          "when": {
            "and": [
              {
                "tag": "highway",
                "in_set": "sidepath_highway"
              },
              {
                "tag": "traffic_sign",
                "exists": false
              },
              {
                "tag": "oneway",
                "eq": "yes"
              },
              {
                "not": {
                  "tag": "oneway:bicycle",
                  "eq": "no"
                }
              }
            ]
          },
          "value": {
            "tag_or": "traffic_sign:forward",
            "or": ""
          }
        }
      ]
    }
  ],
  "exclude_condition": {
    "or": [
      {
        "macro": "standard_exclude"
      },
      {
        "tag": "access",
        "in": [
          "private",
          "no",
          "delivery",
          "permit"
        ]
      },
      {
        "and": [
          {
            "tag": "highway",
            "eq": "footway"
          },
          {
            "tag": "foot",
            "in": [
              "private",
              "no",
              "delivery",
              "permit"
            ]
          }
        ]
      },
      {
        "and": [
          {
            "tag": "highway",
            "eq": "cycleway"
          },
          {
            "tag": "bicycle",
            "in": [
              "private",
              "no",
              "delivery",
              "permit"
            ]
          }
        ]
      },
      {
        "and": [
          {
            "tag": "highway",
            "eq": "service"
          },
          {
            "not": {
              "tag": "bicycle",
              "eq": "designated"
            }
          },
          {
            "not": {
              "first_tag": [
                "bicycle:left",
                "bicycle:right",
                "bicycle:both"
              ],
              "exists": true
            }
          },
          {
            "tag": "service",
            "exists": true
          },
          {
            "not": {
              "tag": "service",
              "eq": "alley"
            }
          }
        ]
      }
    ]
  },
  "osm_fields": [
    "highway",
    "name",
    "ref",
    "surface",
    "smoothness",
    "maxspeed",
    "oneway",
    "oneway:bicycle",
    "lit",
    "bridge",
    "tunnel",
    "operator_type",
    "informal",
    "covered",
    "traffic_sign"
  ],
  "sanitizers": [
    {
      "tag": "bridge",
      "name": "yes_flag"
    },
    {
      "tag": "tunnel",
      "name": "yes_flag"
    },
    {
      "tag": "traffic_sign",
      "name": "traffic_sign"
    }
  ],
  "derivers": [
    "lifecycle",
    "road"
  ],
  "consts": {
    "minzoom": 0
  }
}
