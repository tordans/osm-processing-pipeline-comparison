{
  "lifecycle": {
    "fallback": [
      { "key": "temporary", "sanitize": "temporary" },
      { "key": "lifecycle" },
      { "key": "lifecycle", "from": "parent" }
    ]
  },
  "road": { "shared": "road", "from": "parent_or_obj" },
  "track_minzoom": {
    "default": 0,
    "rules": [
      {
        "when": { "not": { "tag": "tracktype", "in": ["grade1", "grade2"] } },
        "value": 11
      }
    ]
  }
}
