{
  "mtb_scale": [
    {
      "replace": [
        {
          "from": "+",
          "to": ""
        },
        {
          "from": "-",
          "to": ""
        },
        {
          "from": " ",
          "to": ""
        }
      ]
    }
  ],
  "marking": {
    "filter": [
      "solid_line",
      "dashed_line",
      "double_solid_line",
      "barred_area",
      "pictogram",
      "surface"
    ]
  },
  "separation": [
    {
      "cases": {
        "bump": [
          "separation_kerb",
          "lane_separator"
        ],
        "no": [
          "surface"
        ],
        "tree_row": [
          "tree_row;kerb",
          "kerb;tree_row",
          "tree_row;kerb;parking_lane",
          "grass_verge;tree_row"
        ],
        "kerb": [
          "kerb;greenery"
        ],
        "parking_lane": [
          "parking_lane;kerb",
          "solid_line;parking_lane"
        ]
      },
      "on_miss": "keep"
    },
    {
      "filter": [
        "no",
        "bollard",
        "flex_post",
        "vertical_panel",
        "studs",
        "bump",
        "planter",
        "kerb",
        "fence",
        "jersey_barrier",
        "guard_rail",
        "structure",
        "ditch",
        "greenery",
        "hedge",
        "tree_row",
        "cone",
        "kerb;parking_lane",
        "kerb;bollard",
        "yes"
      ]
    }
  ],
  "traffic_mode": [
    {
      "cases": {
        "foot": "foot;bicycle",
        "motor_vehicle": "motorized",
        "no": "none"
      },
      "on_miss": "keep"
    },
    {
      "filter": [
        "no",
        "motor_vehicle",
        "parking",
        "psv",
        "bicycle",
        "foot"
      ]
    }
  ],
  "parking": {
    "cases": {
      "parking": [
        "yes",
        "lane",
        "street_side",
        "on_kerb",
        "half_on_kerb",
        "shoulder",
        "separate"
      ]
    },
    "on_miss": "drop"
  },
  "buffer": [
    {
      "cases": {
        "0": [
          "no",
          "none"
        ]
      },
      "on_miss": "keep"
    },
    "parse_length"
  ],
  "surface_color": {
    "cases": {
      "no": [
        "none",
        "grey",
        "gray",
        "silver",
        "dimgray",
        "#888888",
        "no"
      ],
      "red": [
        "#b5565a",
        "orange",
        "red"
      ],
      "red;green": [
        "green;red",
        "red;green"
      ],
      "green": "green"
    },
    "on_miss": "drop"
  },
  "surface_normalize": {
    "cases": {
      "ground": [
        "earth",
        "mud",
        "clay",
        "dirt",
        "dirt/sand",
        "ground"
      ],
      "large_sett": [
        "cobblestone",
        "unhewn_cobblestone",
