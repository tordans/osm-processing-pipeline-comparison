      "asphalt": "asphalt",
      "paved": "paved",
      "unpaved": "unpaved",
      "concrete": "concrete",
      "concrete:plates": "concrete:plates",
      "concrete:lanes": "concrete:lanes",
      "paving_stones:lanes": "paving_stones:lanes",
      "sett": "sett",
