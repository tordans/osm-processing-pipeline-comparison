    "on_miss": "drop"
  },
  "smoothness_direct": {
    "filter": [
      "excellent",
      "good",
      "intermediate",
      "bad",
      "very_bad"
    ]
  },
  "smoothness_norm": {
    "mapping": {
      "very_good": "excellent",
      "impassable": "very_bad",
      "horrible": "very_bad",
      "very_horrible": "very_bad"
    },
    "on_miss": "drop"
  },
