{
  "table": "bikelanes",
  "consts": {
    "oneway": {
      "value": "assumed_no",
      "consts": {
        "confidence": "not_applicable"
      }
    },
    "minzoom": 0,
    "cost": 1
  },
  "exclude_condition": {
    "macro": "standard_exclude"
  },
  "transforms": [
    {
      "output": "highway",
      "rules": [
        {
          "when": {
            "and": [
              {
                "tag": "highway",
                "exists": true
              },
              {
                "tag": "construction",
                "in_set": "allowed_highway"
              }
            ]
          },
          "value": {
            "tag": "construction"
          }
        }
      ]
    },
    {
      "output": "lifecycle",
      "rules": [
        {
          "when": {
            "and": [
              {
                "tag": "highway",
                "exists": true
              },
              {
                "tag": "construction",
                "in_set": "allowed_highway"
              }
            ]
          },
          "value": "construction"
        },
        {
          "when": {
            "and": [
              {
                "or": [
                  {
                    "tag": "access",
                    "eq": "no"
                  },
                  {
                    "and": [
                      {
                        "tag": "highway",
                        "eq": "cycleway"
                      },
                      {
                        "tag": "bicycle",
                        "eq": "no"
                      }
                    ]
                  },
                  {
                    "and": [
                      {
                        "tag": "highway",
                        "eq": "footway"
                      },
                      {
                        "tag": "foot",
                        "eq": "no"
                      }
                    ]
                  }
                ]
              },
              {
                "or": [
                  {
                    "tag": "access:reason",
                    "contains": "construction",
                    "case_insensitive": true
                  },
                  {
                    "tag": "access:reason",
                    "contains": "baustelle",
                    "case_insensitive": true
                  },
                  {
                    "tag": "description",
                    "contains": "construction",
                    "case_insensitive": true
                  },
                  {
                    "tag": "description",
                    "contains": "baustelle",
                    "case_insensitive": true
                  },
                  {
                    "tag": "note",
                    "contains": "construction",
                    "case_insensitive": true
                  },
                  {
                    "tag": "note",
                    "contains": "baustelle",
                    "case_insensitive": true
                  }
                ]
              }
            ]
          },
          "value": "construction_no_access"
        },
        {
          "when": {
            "and": [
              {
                "or": [
                  {
                    "tag": "access",
                    "eq": "no"
                  },
                  {
                    "and": [
                      {
                        "tag": "highway",
                        "eq": "cycleway"
                      },
                      {
                        "tag": "bicycle",
                        "eq": "no"
                      }
                    ]
                  },
                  {
                    "and": [
                      {
                        "tag": "highway",
                        "eq": "footway"
                      },
                      {
                        "tag": "foot",
                        "eq": "no"
                      }
                    ]
                  }
                ]
              },
              {
                "or": [
                  {
                    "tag": "description",
                    "contains": "sperrung",
                    "case_insensitive": true
                  },
                  {
                    "tag": "description",
                    "contains": "gesperrt",
                    "case_insensitive": true
                  },
                  {
                    "tag": "description",
                    "contains": "blockiert",
                    "case_insensitive": true
                  },
                  {
                    "tag": "description",
                    "contains": "blocked",
                    "case_insensitive": true
                  },
                  {
                    "tag": "description",
                    "contains": "closure",
                    "case_insensitive": true
                  },
                  {
                    "tag": "description",
                    "contains": "closed",
                    "case_insensitive": true
                  },
                  {
                    "tag": "note",
                    "contains": "sperrung",
                    "case_insensitive": true
                  },
                  {
                    "tag": "note",
                    "contains": "gesperrt",
                    "case_insensitive": true
                  },
                  {
                    "tag": "note",
                    "contains": "blockiert",
                    "case_insensitive": true
                  },
                  {
                    "tag": "note",
                    "contains": "blocked",
                    "case_insensitive": true
                  },
                  {
                    "tag": "note",
                    "contains": "closure",
                    "case_insensitive": true
                  },
                  {
                    "tag": "note",
                    "contains": "closed",
                    "case_insensitive": true
                  }
                ]
              }
            ]
          },
          "value": "blocked"
        }
      ]
    },
    {
      "output": "construction",
      "rules": [
        {
          "when": {
            "tag": "lifecycle",
            "eq": "construction"
          },
          "value": null
        }
      ]
    },
    {
      "output": "access",
      "rules": [
        {
          "when": {
            "tag": "lifecycle",
            "in": [
              "construction_no_access",
              "blocked"
            ]
          },
          "value": null
        }
      ]
    },
    {
      "output": "bicycle",
      "rules": [
        {
          "when": {
            "and": [
              {
                "tag": "lifecycle",
                "in": [
                  "construction_no_access",
                  "blocked"
                ]
              },
              {
                "tag": "highway",
                "eq": "cycleway"
              }
            ]
          },
          "value": null
        }
      ]
    },
    {
      "output": "foot",
      "rules": [
        {
          "when": {
            "and": [
              {
                "tag": "lifecycle",
                "in": [
                  "construction_no_access",
                  "blocked"
                ]
              },
              {
                "tag": "highway",
                "eq": "footway"
              }
            ]
          },
          "value": null
        }
      ]
    },
    {
      "output": "oneway:bicycle",
      "rules": [
        {
          "when": {
            "tag": "cycleway",
            "in": [
              "opposite",
              "opposite_lane",
              "opposite_track"
            ]
          },
          "value": "no"
        }
      ]
    },
    {
      "output": "cycleway:left",
      "rules": [
        {
          "when": {
            "tag": "cycleway",
            "eq": "opposite_lane"
          },
          "value": "lane"
        },
        {
          "when": {
            "tag": "cycleway",
            "eq": "opposite_track"
          },
          "value": "track"
        }
      ]
    },
    {
      "output": "cycleway",
      "rules": [
        {
          "when": {
            "tag": "cycleway",
            "in": [
              "opposite",
              "opposite_lane",
              "opposite_track"
            ]
          },
          "value": null
        }
      ]
    },
    {
      "prefix": "construction:",
      "stamp_key": "lifecycle",
      "stamp_value": "construction",
      "stamp_nested_under": [
        "cycleway:",
        "sidewalk:"
      ]
    },
    {
      "output": "cycleway:both",
      "rules": [
        {
          "when": {
            "tag": "cycleway",
            "eq": "no"
          },
          "value": {
            "tag": "cycleway"
          }
        }
      ]
    },
    {
      "output": "cycleway",
      "rules": [
        {
          "when": {
            "tag": "cycleway",
            "eq": "no"
          },
          "value": null
        }
      ]
    },
    {
      "prefix": "cycleway"
    },
    {
      "output": "traffic_sign",
      "rules": [
        {
          "when": {
            "and": [
              {
                "tag": "highway",
                "in_set": "sidepath_highway"
              },
              {
                "tag": "traffic_sign",
                "exists": false
              },
              {
                "tag": "oneway",
                "eq": "yes"
              },
              {
                "not": {
                  "tag": "oneway:bicycle",
                  "eq": "no"
                }
              }
            ]
          },
          "value": {
            "tag_or": "traffic_sign:forward",
            "or": ""
          }
        }
      ]
    }
  ],
  "split_sides": [
    {
      "highway": "cycleway",
      "prefix": "cycleway",
      "directed_keys": [
        "cycleway:lanes",
        "bicycle:lanes"
      ],
      "self_directed_keys": [
        "traffic_sign"
      ]
    },
    {
      "highway": "footway",
      "prefix": "sidewalk",
      "self_directed_keys": [
        "traffic_sign"
      ]
    }
  ],
  "osm_fields": [
    {
      "output": "name",
      "source": {
        "fallback": [
          {
            "key": "name"
          },
          {
            "key": "name",
            "from": "parent"
          }
        ]
      }
    },
    "surface",
    "smoothness",
    "width",
    "source:width",
    {
      "output": "bridge",
      "source": {
        "key": "bridge",
        "from": "parent"
      }
    },
    {
      "output": "tunnel",
      "source": {
        "key": "tunnel",
        "from": "parent"
      }
    },
    "oneway",
    {
      "output": "oneway:bicycle",
      "source": {
        "fallback": [
          {
            "key": "oneway:bicycle"
          },
          {
            "key": "oneway:bicycle",
            "from": "parent"
          }
        ]
      }
    },
    "traffic_sign",
    {
      "output": "is_directed",
      "source": {
        "rules": [
          {
            "when": {
              "tag": "oneway",
              "in": [
                "yes",
                "-1"
              ]
            },
            "value": true
          }
        ],
        "default": false
      }
    },
    {
      "output": "informal",
      "source": {
        "key": "informal",
        "from": "parent"
      }
    },
    {
      "output": "covered",
      "source": {
        "key": "covered",
        "from": "parent"
      }
    },
    {
      "output": "operator_type",
      "source": {
        "key": "operator_type",
        "from": "parent"
      }
    },
    {
      "output": "mapillary",
      "source": {
        "key": "mapillary",
        "from": "parent"
      }
    },
    "segregated",
    "bicycle",
    "foot",
    "description",
    "note",
    "temporary",
    "separation:left",
    "separation:right",
    "separation:both",
    "marking:left",
    "marking:right",
    "marking:both",
    "traffic_mode:left",
    "traffic_mode:right",
    "traffic_mode:both",
    "buffer:left",
    "buffer:right",
    "buffer:both",
    {
      "output": "surface:colour",
      "source": {
        "keys": [
          "surface:colour",
          "surface:color"
        ]
      }
    }
  ],
  "sanitizers": [
    {
      "tag": "traffic_sign",
      "name": "traffic_sign"
    },
    {
      "tag": "separation_left",
      "name": "separation",
      "in": [
        "separation:left",
        "separation:both",
        "separation"
      ]
    },
    {
      "tag": "separation_right",
      "name": "separation",
      "in": [
        "separation:right",
        "separation:both"
      ]
    },
    {
      "tag": "marking_left",
      "name": "marking",
      "in": [
        "marking:left",
        "marking:both",
        "marking"
      ]
    },
    {
      "tag": "marking_right",
      "name": "marking",
      "in": [
        "marking:right",
        "marking:both"
      ]
    },
    {
      "tag": "buffer_left",
      "name": "buffer",
      "in": [
        "buffer:left",
        "buffer:both",
        "buffer"
      ]
    },
    {
      "tag": "buffer_right",
      "name": "buffer",
      "in": [
        "buffer:right",
        "buffer:both"
      ]
    },
    {
      "tag": "surface_color",
      "name": "surface_color",
      "in": [
        "surface:colour",
        "surface:color"
      ]
    },
    {
      "tag": "bridge",
      "name": "yes_flag",
      "from": "parent_or_obj"
    },
    {
      "tag": "tunnel",
      "name": "yes_flag",
      "from": "parent_or_obj"
    },
    {
      "tag": "width",
      "name": "parse_length"
    },
    {
      "tag": "width_effective",
      "name": "parse_length",
      "in": "width:effective"
    }
  ],
  "derivers": [
    "oneway",
    "lifecycle",
    "surface",
    "smoothness",
    "traffic_mode_left",
    "traffic_mode_right",
    "road"
  ]
}
