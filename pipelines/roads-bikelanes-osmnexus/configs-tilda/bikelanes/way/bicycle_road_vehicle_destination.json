{
  "condition": {
    "and": [
      {
        "macro": "is_bicycle_road"
      },
      {
        "or": [
          {
            "tag": "traffic_sign",
            "contains": "1020-30"
          },
          {
            "tag": "traffic_sign",
            "contains": "Kraftfahrzeuge-frei"
          },
          {
            "tag": "traffic_sign",
            "contains": "Kfz-Verkehr frei"
          },
          {
            "tag": "traffic_sign",
            "contains": "KFZ frei"
          },
          {
            "tag": "vehicle",
            "in": [
              "destination",
              "yes"
            ]
          },
          {
            "tag": "motor_vehicle",
            "in": [
              "destination",
              "yes"
            ]
          }
        ]
      }
    ]
  },
  "excludes": [
    "crossing",
    "cycleway_link",
    "cycleway_on_highway_protected",
    "data_no",
    "not_expected",
    "separate_geometry"
