    },
    {
      "deriver": "traffic_mode_left_from_parking_both",
      "output": "traffic_mode_left"
    },
    {
      "deriver": "traffic_mode_right_from_parking_both",
      "output": "traffic_mode_right"
    }
  ],
  "consts": {
    "oneway": {
      "value": "assumed_no",
      "consts": {
        "confidence": "high"
      }
    }
  }
}
