diff --git a/src/output/geojsonseq.rs b/src/output/geojsonseq.rs
new file mode 100644
index 0000000..4c37ae0
--- /dev/null
+++ b/src/output/geojsonseq.rs
@@ -0,0 +1,226 @@
+//! Builds one `<table>.ndjson` per topic from the CSV output `--output geojsonseq` shares with
+//! `--output csv` (`{table}.csv` + `edges.csv`). One GeoJSON Feature per tag row (not per edge
+//! segment), streamed line-by-line for tippecanoe / geopandas. Way geometries are the whole-way
+//! LineString (merged edge segments); node rows are Points; relation rows are MultiLineStrings of
+//! member-way geometries when available.
+
+use std::collections::HashMap;
+use std::io::{BufWriter, Write};
+use std::path::Path;
+
+use serde_json::{json, Map, Value};
+use tracing::warn;
+
+use crate::output::geometry::{linestring_from_ewkb, mercator_to_wgs84, point_from_ewkb};
+use crate::output::rows::{GEOM_COLUMNS, NODE_COLUMNS, TAG_COLUMNS, WAY_GEOM_COLUMNS};
+
+struct EdgeGeom {
+    seg_idx: usize,
+    coordinates: Vec<[f64; 2]>,
+}
+
+fn lonlat_coordinates(geom: &[u8]) -> anyhow::Result<Vec<[f64; 2]>> {
+    Ok(linestring_from_ewkb(geom)?
+        .into_iter()
+        .map(|(x, y)| {
+            let (lon, lat) = mercator_to_wgs84(x, y);
+            [lon, lat]
+        })
+        .collect())
+}
+
+fn lonlat_point(geom: &[u8]) -> anyhow::Result<[f64; 2]> {
+    let (x, y) = point_from_ewkb(geom)?;
+    let (lon, lat) = mercator_to_wgs84(x, y);
+    Ok([lon, lat])
+}
+
+fn read_way_geometries(path: &Path) -> anyhow::Result<HashMap<i64, Vec<[f64; 2]>>> {
+    debug_assert_eq!(WAY_GEOM_COLUMNS, "osm_id,geom,length_m");
+    let mut reader = csv::Reader::from_path(path)?;
+    let mut by_osm_id = HashMap::new();
+    for result in reader.records() {
+        let record = result?;
+        let geom_hex = &record[1];
+        if geom_hex.is_empty() {
+            continue;
+        }
+        let osm_id: i64 = record[0].parse()?;
+        by_osm_id.insert(osm_id, lonlat_coordinates(&hex::decode(geom_hex)?)?);
+    }
+    Ok(by_osm_id)
+}
+
+fn read_nodes(path: &Path) -> anyhow::Result<HashMap<i64, Vec<u8>>> {
+    debug_assert_eq!(NODE_COLUMNS, "id,osm_id,geom");
+    let mut reader = csv::Reader::from_path(path)?;
+    let mut by_osm_id = HashMap::new();
+    for result in reader.records() {
+        let record = result?;
+        let geom_hex = &record[2];
+        if geom_hex.is_empty() {
+            continue;
+        }
+        let osm_id: i64 = record[1].parse()?;
+        by_osm_id.insert(osm_id, hex::decode(geom_hex)?);
+    }
+    Ok(by_osm_id)
+}
+
+fn read_relation_members(path: &Path) -> anyhow::Result<HashMap<i64, Vec<i64>>> {
+    let mut reader = csv::Reader::from_path(path)?;
+    let mut by_relation_id: HashMap<i64, Vec<i64>> = HashMap::new();
+    for result in reader.records() {
+        let record = result?;
+        let relation_osm_id: i64 = record[0].parse()?;
+        let way_osm_id: i64 = record[1].parse()?;
+        by_relation_id.entry(relation_osm_id).or_default().push(way_osm_id);
+    }
+    Ok(by_relation_id)
+}
+
+fn read_edges(path: &Path) -> anyhow::Result<HashMap<i64, Vec<EdgeGeom>>> {
+    debug_assert_eq!(GEOM_COLUMNS, "osm_id,seg_idx,start_id,end_id,geom,length_m,total_length_m,cost,reverse_cost");
+    let mut reader = csv::Reader::from_path(path)?;
+    let mut by_osm_id: HashMap<i64, Vec<EdgeGeom>> = HashMap::new();
+    for result in reader.records() {
+        let record = result?;
+        let geom_hex = &record[4];
+        if geom_hex.is_empty() {
+            continue;
+        }
+        let osm_id: i64 = record[0].parse()?;
+        let seg_idx: usize = record[1].parse()?;
+        let coordinates = lonlat_coordinates(&hex::decode(geom_hex)?)?;
+        by_osm_id.entry(osm_id).or_default().push(EdgeGeom { seg_idx, coordinates });
+    }
+    for segments in by_osm_id.values_mut() {
+        segments.sort_by_key(|s| s.seg_idx);
+    }
+    Ok(by_osm_id)
+}
+
+/// Merge intersection-split edge segments into one whole-way LineString (WGS84 lon/lat).
+fn merged_way_linestring(segments: &[EdgeGeom]) -> Vec<[f64; 2]> {
+    let mut coords = Vec::new();
+    for (i, segment) in segments.iter().enumerate() {
+        let start = if i == 0 { 0 } else { 1 };
+        coords.extend_from_slice(&segment.coordinates[start..]);
+    }
+    coords
+}
+
+fn way_linestring(
+    osm_id: i64,
+    way_geoms: &HashMap<i64, Vec<[f64; 2]>>,
+    edges: &HashMap<i64, Vec<EdgeGeom>>,
+) -> Option<Vec<[f64; 2]>> {
+    if let Some(coords) = way_geoms.get(&osm_id) {
+        return Some(coords.clone());
+    }
+    edges.get(&osm_id).map(|segments| merged_way_linestring(segments))
+}
+
+fn merge_properties(target: &mut Map<String, Value>, json_str: &str) {
+    if let Ok(Value::Object(map)) = serde_json::from_str(json_str) {
+        target.extend(map);
+    }
+}
+
+fn row_properties(record: &csv::StringRecord) -> Map<String, Value> {
+    let osm_id: i64 = record[0].parse().unwrap_or(0);
+    let mut properties = Map::new();
+    properties.insert("osm_id".to_owned(), json!(osm_id));
+    properties.insert("id".to_owned(), json!(&record[2]));
+    merge_properties(&mut properties, &record[3]);
+    merge_properties(&mut properties, &record[4]);
+    merge_properties(&mut properties, &record[5]);
+    properties
+}
+
+/// Reads `{table}.csv` (per `tables`) + geometry sidecars from `out_dir` and writes
+/// `{table}.ndjson`: one `{"type":"Feature",...}` JSON document per line.
+pub fn write_geojsonseq_from_csv(out_dir: &Path, tables: &[String]) -> anyhow::Result<()> {
+    debug_assert_eq!(TAG_COLUMNS, "osm_id,osm_type,id,osm,derived,private,meta");
+    let edges = read_edges(&out_dir.join("edges.csv"))?;
+    let way_geoms_path = out_dir.join("way_geometries.csv");
+    let way_geoms = if way_geoms_path.exists() {
+        read_way_geometries(&way_geoms_path)?
+    } else {
+        HashMap::new()
+    };
+    let nodes_path = out_dir.join("nodes.csv");
+    let nodes = if nodes_path.exists() { read_nodes(&nodes_path)? } else { HashMap::new() };
+    let members_path = out_dir.join("relation_members.csv");
+    let relation_members =
+        if members_path.exists() { read_relation_members(&members_path)? } else { HashMap::new() };
+
+    let mut relation_rows_skipped = 0usize;
+
+    for table in tables {
+        let csv_path = out_dir.join(format!("{table}.csv"));
+        let ndjson_path = out_dir.join(format!("{table}.ndjson"));
+        let mut reader = csv::Reader::from_path(&csv_path)?;
+        let mut writer = BufWriter::new(std::fs::File::create(&ndjson_path)?);
+
+        for result in reader.records() {
+            let record = result?;
+            let osm_id: i64 = record[0].parse()?;
+            let osm_type = &record[1];
+            let properties = row_properties(&record);
+
+            let feature = match osm_type.as_bytes() {
+                b"N" => {
+                    let Some(geom) = nodes.get(&osm_id) else { continue };
+                    let Ok(coordinates) = lonlat_point(geom) else { continue };
+                    json!({
+                        "type": "Feature",
+                        "geometry": { "type": "Point", "coordinates": coordinates },
+                        "properties": properties,
+                    })
+                }
+                b"R" => {
+                    let Some(way_ids) = relation_members.get(&osm_id) else {
+                        relation_rows_skipped += 1;
+                        continue;
+                    };
+                    let linestrings: Vec<Vec<[f64; 2]>> = way_ids
+                        .iter()
+                        .filter_map(|way_id| way_linestring(*way_id, &way_geoms, &edges))
+                        .collect();
+                    if linestrings.is_empty() {
+                        relation_rows_skipped += 1;
+                        continue;
+                    }
+                    json!({
+                        "type": "Feature",
+                        "geometry": { "type": "MultiLineString", "coordinates": linestrings },
+                        "properties": properties,
+                    })
+                }
+                _ => {
+                    let Some(coordinates) = way_linestring(osm_id, &way_geoms, &edges) else {
+                        continue;
+                    };
+                    json!({
+                        "type": "Feature",
+                        "geometry": { "type": "LineString", "coordinates": coordinates },
+                        "properties": properties,
+                    })
+                }
+            };
+
+            serde_json::to_writer(&mut writer, &feature)?;
+            writer.write_all(b"\n")?;
+        }
+        writer.flush()?;
+    }
+
+    if relation_rows_skipped > 0 {
+        warn!(
+            "geojsonseq: skipped {relation_rows_skipped} relation row(s) with no member-way geometry"
+        );
+    }
+
+    Ok(())
+}
